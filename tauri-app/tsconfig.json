{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["../browser-ide/src/*"],
      "@/components/*": ["../browser-ide/src/components/*"],
      "@/services/*": ["../browser-ide/src/services/*"],
      "@/stores/*": ["../browser-ide/src/stores/*"],
      "@/types/*": ["../browser-ide/src/types/*"],
      "@/utils/*": ["../browser-ide/src/utils/*"],
      "mml2vgm-wasm": ["../mml2vgm-wasm/pkg"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
