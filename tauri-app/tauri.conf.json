{
  "$schema": "https://json.schemastore.org/tauri2",
  "productName": "mml2vgm",
  "identifier": "com.mml2vgm.desktop",
  "version": "0.1.0",
  "app": {
    "windows": [
      {
        "title": "mml2vgm",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true,
        "resizable": true,
        "maximizable": true,
        "closable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "capabilities": [
        {
          "identifier": "dialog-open",
          "description": "Allow open dialog",
          "permissions": ["dialog:open"]
        },
        {
          "identifier": "clipboard-all",
          "description": "Allow clipboard access",
          "permissions": ["clipboard:read", "clipboard:write"]
        },
        {
          "identifier": "notification-show",
          "description": "Allow notifications",
          "permissions": ["notification:show"]
        },
        {
          "identifier": "fs-read-mml",
          "description": "Read MML Files",
          "permissions": [
            {
              "identifier": "fs:allow-read",
              "allow": ["**/*.gwi", "**/*.mml", "**/*.muc", "**/*.mdl", "**/*.mus", "**/*.txt"]
            }
          ]
        },
        {
          "identifier": "fs-write-vgm",
          "description": "Write VGM Files",
          "permissions": [
            {
              "identifier": "fs:allow-write",
              "allow": ["**/*.vgm", "**/*.xgm", "**/*.zgm", "**/*.wav"]
            }
          ]
        }
      ]
    }
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "longDescription": "mml2vgm is a complete MML to VGM/XGM/ZGM compiler with built-in IDE",
    "shortDescription": "MML to VGM compiler IDE",
    "copyright": "Copyright © 2026 mml2vgm Team",
    "category": "Utility"
  }
}
